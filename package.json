{
  "name": "deepseek-harness",
  "version": "0.2.0",
  "description": "Local-first, safety-gated CLI and MCP harness for bounded DeepSeek batch and corpus workloads.",
  "license": "MIT",
  "author": "DeepSeek Harness contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tylerbuilds/deepseek-harness.git"
  },
  "bugs": {
    "url": "https://github.com/tylerbuilds/deepseek-harness/issues"
  },
  "homepage": "https://github.com/tylerbuilds/deepseek-harness#readme",
  "keywords": [
    "deepseek",
    "mcp",
    "llm",
    "batch-processing",
    "ocr",
    "translation",
    "local-first"
  ],
  "type": "module",
  "bin": {
    "deepseek-harness": "./dist/src/cli.js",
    "deepseek-harness-mcp": "./dist/src/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "test:e2e": "npm run build && node --test dist/test/e2e.test.js",
    "doctor": "node dist/src/cli.js doctor",
    "install:local": "bash scripts/install-local.sh",
    "mcp:config": "node dist/src/cli.js mcp-config",
    "mcp:config:codex": "node dist/src/cli.js mcp-config --format codex-toml",
    "mcp:smoke": "node scripts/smoke-mcp.mjs",
    "mcp:inspect": "npx --yes @modelcontextprotocol/inspector node dist/src/mcp.js",
    "package:smoke": "node scripts/smoke-package.mjs",
    "prepack": "npm run build",
    "pack:check": "npm run build && node scripts/check-package-contents.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "ink": "^7.1.1",
    "react": "^19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/react": "^19.2.7",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist/src/agent/cli.js",
    "dist/src/agent/context.js",
    "dist/src/agent/dispatch.js",
    "dist/src/agent/events.js",
    "dist/src/agent/jobs.js",
    "dist/src/agent/loop.js",
    "dist/src/agent/prompts.js",
    "dist/src/agent/session.js",
    "dist/src/agent/stream.js",
    "dist/src/agent/tools.js",
    "dist/src/agent/tui-state.js",
    "dist/src/agent/tui.js",
    "dist/src/approval.js",
    "dist/src/budget.js",
    "dist/src/cli.js",
    "dist/src/corpus.js",
    "dist/src/corpus_authoring.js",
    "dist/src/corpus_ingest.js",
    "dist/src/corpus_media.js",
    "dist/src/corpus_ocr.js",
    "dist/src/corpus_supervisor.js",
    "dist/src/corpus_translation.js",
    "dist/src/corpus_translation_memory.js",
    "dist/src/corpus_translation_review.js",
    "dist/src/corpus_validation.js",
    "dist/src/cost.js",
    "dist/src/errors.js",
    "dist/src/index.js",
    "dist/src/mcp.js",
    "dist/src/product.js",
    "dist/package.json",
    "dist/src/paths.js",
    "dist/src/privacy.js",
    "dist/src/runner.js",
    "dist/src/schema.js",
    "dist/src/store.js",
    "dist/src/transport.js",
    "dist/src/usage.js",
    "dist/src/workloads.js",
    "examples/basic-run.json",
    "examples/corpus-basic.json",
    "examples/corpus-deepseek-fake.json",
    "examples/corpus-jsonl-dataset.json",
    "examples/failure-injection.json",
    "examples/live-deepseek-blocked.json",
    "examples/live-micro-smoke-template.json",
    "examples/longform-outline.json",
    "examples/model-comparison-base.json",
    "examples/translation-glossary.json",
    "examples/workload-benchmark.json",
    "scripts/install-local.sh",
    "scripts/smoke-mcp.mjs",
    "scripts/ocr-vision.swift",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "docs/user-guide.md",
    "docs/operator-guide.md",
    "docs/corpus-heavy-workloads.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
